Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Areatorigin", "=", 
    RowBox[{
     FractionBox["1", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       SuperscriptBox[
        RowBox[{"Tanh", "[", 
         RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}], "2"]}]], "h", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "4"}], "+", 
       RowBox[{"4", " ", "\[Pi]", " ", "x", " ", 
        RowBox[{"Cot", "[", 
         RowBox[{"\[Pi]", " ", "x"}], "]"}]}], "+", 
       RowBox[{"4", " ", 
        RowBox[{"Cos", "[", 
         RowBox[{"\[Pi]", " ", "x"}], "]"}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"t", "+", 
          RowBox[{"\[Pi]", " ", "x"}]}], "]"}], " ", 
        RowBox[{"Tanh", "[", 
         RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}], "-", 
       RowBox[{"2", " ", 
        RowBox[{"Csc", "[", 
         RowBox[{"\[Pi]", " ", "x"}], "]"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "2"}], " ", "\[Pi]", " ", "x"}], "+", 
          RowBox[{"Sin", "[", 
           RowBox[{"2", " ", "\[Pi]", " ", "x"}], "]"}]}], ")"}], " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"t", "+", 
          RowBox[{"\[Pi]", " ", "x"}]}], "]"}], " ", 
        RowBox[{"Tanh", "[", 
         RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}], "+", 
       RowBox[{"4", " ", 
        SuperscriptBox[
         RowBox[{"Tanh", "[", 
          RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}], "2"]}], "+", 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Log", "[", 
           RowBox[{"1", "+", 
            RowBox[{"\[ImaginaryI]", " ", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{
               RowBox[{"-", "\[ImaginaryI]"}], " ", "t"}]], " ", 
             RowBox[{"Tanh", "[", 
              RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}]}], "]"}], "-", 
          RowBox[{"Log", "[", 
           RowBox[{"1", "-", 
            RowBox[{"\[ImaginaryI]", " ", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{"\[ImaginaryI]", " ", "t"}]], " ", 
             RowBox[{"Tanh", "[", 
              RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}]}], "]"}], "-", 
          RowBox[{"Log", "[", 
           RowBox[{"1", "+", 
            RowBox[{"\[ImaginaryI]", " ", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{
               RowBox[{"-", "\[ImaginaryI]"}], " ", 
               RowBox[{"(", 
                RowBox[{"t", "+", 
                 RowBox[{"2", " ", "\[Pi]", " ", "x"}]}], ")"}]}]], " ", 
             RowBox[{"Tanh", "[", 
              RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}]}], "]"}], "+", 
          RowBox[{"Log", "[", 
           RowBox[{"1", "-", 
            RowBox[{"\[ImaginaryI]", " ", 
             SuperscriptBox["\[ExponentialE]", 
              RowBox[{"\[ImaginaryI]", " ", 
               RowBox[{"(", 
                RowBox[{"t", "+", 
                 RowBox[{"2", " ", "\[Pi]", " ", "x"}]}], ")"}]}]], " ", 
             RowBox[{"Tanh", "[", 
              RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}]}], "]"}]}], 
         ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"Csc", "[", 
            RowBox[{"\[Pi]", " ", "x"}], "]"}], " ", 
           RowBox[{"Sin", "[", 
            RowBox[{"t", "+", 
             RowBox[{"\[Pi]", " ", "x"}]}], "]"}], " ", 
           RowBox[{"Tanh", "[", 
            RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}], "+", 
          RowBox[{
           RowBox[{"Cot", "[", 
            RowBox[{"\[Pi]", " ", "x"}], "]"}], " ", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             SuperscriptBox[
              RowBox[{"Tanh", "[", 
               RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}], "2"]}], 
            ")"}]}]}], ")"}]}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"bulkEE2ndorigin", "=", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Pi]", " ", "x"}], ")"}], 
      RowBox[{"8", "h"}]]}], " ", 
    FractionBox[
     RowBox[{
      RowBox[{"Gamma", "[", 
       FractionBox["3", "2"], "]"}], 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"4", "h"}], "+", "1"}], "]"}]}], 
     RowBox[{"Gamma", "[", 
      RowBox[{
       RowBox[{"4", "h"}], "+", 
       FractionBox["3", "2"]}], "]"}]], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cosh", "[", 
        RowBox[{"2", " ", "n", " ", "\[Gamma]", " ", "T"}], "]"}], "+", 
       RowBox[{
        RowBox[{"Sinh", "[", 
         RowBox[{"2", " ", "n", " ", "\[Gamma]", " ", "T"}], "]"}], 
        RowBox[{"Sin", "[", 
         RowBox[{"t", "+", " ", 
          RowBox[{"\[Pi]", " ", "x"}]}], "]"}]}]}], ")"}], 
     RowBox[{
      RowBox[{"-", "4"}], "h"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Stotorigin", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Areatorigin", "+", "  ", "bulkEE2ndorigin"}], ")"}], "/.", 
     RowBox[{"{", 
      RowBox[{"t", "->", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "\[Pi]", " ", "a"}]}], "}"}]}], "//", 
    "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"plot2", "=", 
   RowBox[{"Plot3D", "[", 
    RowBox[{
     RowBox[{"Stotorigin", "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"T", "->", "1"}], ",", 
        RowBox[{"\[Gamma]", "->", "1.4"}], ",", 
        RowBox[{"h", "->", "3"}], ",", " ", 
        RowBox[{"x", "->", "0.01"}]}], "}"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"a", ",", "0.2", ",", "0.3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "0", ",", "5"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<a\>\"", ",", "Bold", ",", "14"}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<nT\>\"", ",", "Bold", ",", "14"}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"Subscript", "[", 
           RowBox[{"S", ",", "EE"}], "]"}], ",", "Bold", ",", "14"}], "]"}]}],
        "}"}]}], ",", 
     RowBox[{"Background", "->", "White"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.990544789043022*^9, 3.990544815390801*^9}, {
  3.9905448497468843`*^9, 3.990544917705117*^9}, {3.9905449906089983`*^9, 
  3.990545035914337*^9}, {3.990546242308752*^9, 3.990546397608379*^9}, {
  3.990546460360441*^9, 3.990546518272087*^9}, {3.990546580729343*^9, 
  3.990546588379714*^9}, {3.990546641986079*^9, 3.990546667389843*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"dee992a5-6267-4ca3-aef4-a350da8d1aec"],

