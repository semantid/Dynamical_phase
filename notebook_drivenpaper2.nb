Cell[TextData[{
 StyleBox["Note",
  FontVariations->{"Underline"->True},
  FontColor->RGBColor[0.6, 0.4, 0.2]],
 ": We do not need the n dependent part while summing over m. Hence we \
exclude the factor  ",
 Cell[BoxData[
  FormBox[
   FractionBox["1", 
    RowBox[{
     RowBox[{"n", "!"}], 
     RowBox[{"Gamma", "[", 
      RowBox[{"2", "h"}], "]"}]}]], TraditionalForm]],ExpressionUUID->
  "d1b1c894-0919-4b4f-8065-8586e27860f5"],
 " as of now. We note the area term has a cot \[Pi]x and a non-cot \[Pi]x \
term. We sum them separately. We consider non-cot \[Pi]x term first."
}], "SubitemParagraph",
 CellChangeTimes->{{3.988447757622875*^9, 3.988447876168638*^9}, 
   3.9884479908804007`*^9, {3.988448231488714*^9, 3.988448339183405*^9}, {
