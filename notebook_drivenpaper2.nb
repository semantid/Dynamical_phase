 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["J", "2"], " ", "and", " ", 
    SubscriptBox["J", "5"], "  ", "consists", " ", "of", " ", "two", " ", 
    RowBox[{"terms", ".", " ", "We"}], " ", "denote", " ", "the", " ", "term",
     " ", "proportional", " ", "to", " ", "mn", "  "}], TraditionalForm]],
  ExpressionUUID->"0b251a24-4535-4c9b-85ad-9d810e62574c"],
 "with subscript p, ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", "ip"], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"de0c2488-6d32-49d3-aa68-11aa23acc9c3"],
 ". The other term is denoted by subscript s,",
 StyleBox[" ",
  FontWeight->"Bold"],
 Cell[BoxData[
  FormBox[
   SubscriptBox["R", 
    RowBox[{"is", "."}]], TraditionalForm]],
  FontWeight->"Bold",ExpressionUUID->"1327e40e-410d-4dd1-bd6a-b589e9b172ed"]
}], "Text",
