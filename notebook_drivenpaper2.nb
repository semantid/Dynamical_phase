Cell[CellGroupData[{

Cell["Branch I and II : value of cos \[CurlyPhi](r) and sin \[CurlyPhi](r)", \
"Item",
 CellChangeTimes->{{3.9884332247985888`*^9, 
  3.988433253430229*^9}},ExpressionUUID->"00102d20-3984-44a6-b16b-\
d6326d7a38b7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"cos\[CurlyPhi]rB1m", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{"(", 
          RowBox[{
           SqrtBox[
            RowBox[{"1", "+", 
             SuperscriptBox["r", "2"]}]], "+", 
           SqrtBox[
            RowBox[{
             SuperscriptBox["r", "2"], "-", 
             SuperscriptBox["rmin", "2"]}]]}], ")"}], 
         RowBox[{"r", " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", 
            SuperscriptBox["rmin", "2"]}], ")"}]}]]}], 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["r", "2"], "-", 
         RowBox[{
          SqrtBox[
           RowBox[{"1", "+", 
            SuperscriptBox["r", "2"]}]], " ", 
          SqrtBox[
           RowBox[{
            SuperscriptBox["r", "2"], "-", 
            SuperscriptBox["rmin", "2"]}]]}]}], ")"}]}], ")"}]}], "//", 
    "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sin\[CurlyPhi]rB1m", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "rmin"}], "/", "r"}], " ", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"rmin", "^", "2"}]}], ")"}]}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"r", "^", "2"}], "-", 
           RowBox[{"rmin", "^", "2"}]}], "]"}], "+", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", "+", 
           RowBox[{"r", "^", "2"}]}], "]"}]}], ")"}]}], ")"}]}], "//", 
    "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"sin\[CurlyPhi]rB2m", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], 
     FractionBox[
      RowBox[{"rmin", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          SqrtBox[
           RowBox[{"1", "+", 
            SuperscriptBox["r", "2"]}]]}], "+", 
         SqrtBox[
          RowBox[{
           SuperscriptBox["r", "2"], "-", 
           SuperscriptBox["rmin", "2"]}]]}], ")"}]}], 
      RowBox[{"r", " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["rmin", "2"]}], ")"}]}]]}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cos\[CurlyPhi]rB2m", "=", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{
      RowBox[{
       FractionBox[
        RowBox[{
         SuperscriptBox["r", "2"], "+", 
         SqrtBox[
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "+", 
             SuperscriptBox["r", "2"]}], ")"}], " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"r", "^", "2"}], "-", 
             RowBox[{"rmin", "^", "2"}]}], ")"}], " "}]]}], 
        RowBox[{"rmin", " "}]], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "rmin"}], "/", "r"}], ")"}], 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"r", "^", "2"}], "-", 
            RowBox[{"rmin", "^", "2"}]}], "]"}], "-", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "+", 
            RowBox[{"r", "^", "2"}]}], "]"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"rmin", "^", "2"}]}], ")"}]}]}], ",", 
      RowBox[{"r", ">", "0"}]}], "]"}], "//", "FullSimplify"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.988433208655037*^9, 
  3.988433215623105*^9}},ExpressionUUID->"00e84be4-462f-486c-aaa8-\
6c1dca01be78"]
}, Open  ]],

