             RowBox[{"(", 
              RowBox[{"t", "+", 
               RowBox[{"2", " ", "\[Pi]", " ", "x"}]}], ")"}]}]], " ", 
           RowBox[{"Tanh", "[", 
            RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}]}], "]"}], "+", 
        RowBox[{"Log", "[", 
