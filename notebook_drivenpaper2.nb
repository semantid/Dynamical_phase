              RowBox[{"h", " ", 
               RowBox[{"(", 
                RowBox[{"1", "+", "m", "+", "n"}], ")"}]}]}], ")"}], " ", 
            RowBox[{"Hypergeometric2F1", "[", 
             RowBox[{"1", ",", 
              RowBox[{"1", "-", 
               RowBox[{"2", " ", "h"}]}], ",", 
              RowBox[{
               FractionBox["1", "2"], " ", 
               RowBox[{"(", 
                RowBox[{"3", "+", "m", "+", "n"}], ")"}]}], ",", 
              RowBox[{"-", 
               SuperscriptBox["r", "2"]}]}], "]"}]}], 
           RowBox[{"1", "+", "m", "+", "n"}]]}], ")"}]}], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"m", "-", "n"}], ")"}], "2"]], "+", 
      RowBox[{"m", " ", "n", " ", 
       SubscriptBox["c", "p"]}]}], 
     SqrtBox[
      RowBox[{"1", "+", 
       SuperscriptBox["r", "2"]}]]], "+", "r\[CurlyPhi]asymp"}], "//", 
   "Simplify"}]}]], "Input",
