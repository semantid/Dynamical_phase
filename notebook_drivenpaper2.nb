Cell[BoxData[
 RowBox[{
  RowBox[{"dfull", "[", 
   RowBox[{"m_", ",", "r_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"32", " ", "h", " ", "\[Pi]", " ", 
    SuperscriptBox["r", 
     RowBox[{"2", " ", "m"}]], " ", 
