       RowBox[{"2", "h"}], "+", "m"}], "]"}], 
     RowBox[{"Gamma", "[", 
      RowBox[{"2", "h"}], "]"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
