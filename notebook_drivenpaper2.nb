Cell[TextData[{
 " The Einstein\[CloseCurlyQuote]s equation is linear at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"O", "(", 
    SubscriptBox["G", "N"]}], TraditionalForm]],ExpressionUUID->
  "48bf9bb3-4db5-49b9-8930-6c9ebc2f7426"],
 "). There are three distinct kind of terms in the metric ansatz. We solve \
them separately and show sum of them satisfies the \
Einstein\[CloseCurlyQuote]s equation at the end."
}], "Text",
 CellChangeTimes->{{3.978266704657197*^9, 3.978266844444786*^9}, {
