             RowBox[{"-", "\[ImaginaryI]"}], " ", "t"}]], " ", 
           RowBox[{"Tanh", "[", 
            RowBox[{"n", " ", "T", " ", "\[Gamma]"}], "]"}]}]}], "]"}], "-", 
        RowBox[{"Log", "[", 
         RowBox[{"1", "-", 
