Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"f", "[", "r_", "]"}], ":=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{
     RowBox[{
      SuperscriptBox["r", 
       RowBox[{"-", "m"}]], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "+", 
         SuperscriptBox["r", "2"]}], ")"}], 
       RowBox[{"h", "+", 
        FractionBox["m", "2"], "+", "n"}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"N1", " ", 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{
           RowBox[{"1", "+", "n"}], ",", 
           RowBox[{
            RowBox[{"2", " ", "h"}], "+", "n"}], ",", 
           RowBox[{"1", "-", "m"}], ",", 
           RowBox[{"-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}], "+", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", "r", ")"}], 
          RowBox[{"2", " ", "m"}]], " ", "N2", " ", 
         RowBox[{"Hypergeometric2F1", "[", 
          RowBox[{
           RowBox[{"1", "+", "m", "+", "n"}], ",", 
           RowBox[{
            RowBox[{"2", " ", "h"}], "+", "m", "+", "n"}], ",", 
           RowBox[{"1", "+", "m"}], ",", 
           RowBox[{"-", 
            SuperscriptBox["r", "2"]}]}], "]"}]}]}], ")"}]}], "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"N1", "->", "0"}], ",", " ", 
       RowBox[{"N2", "->", "1"}]}], "}"}]}], ",", 
    RowBox[{"r", ">", "0"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["f", 
    RowBox[{"m", ",", "0"}]], "[", "r_", "]"}], ":=", 
  RowBox[{
   RowBox[{"f", "[", "r", "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{"n", "->", "0"}], "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["f", 
    RowBox[{"n", ",", "0"}]], "[", "r_", "]"}], ":=", 
  RowBox[{
   RowBox[{
    SubscriptBox["f", 
     RowBox[{"m", ",", "0"}]], "[", "r", "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{"m", "->", "n"}], "}"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Delta]tt", "=", 
   RowBox[{
    RowBox[{"2", " ", 
     RowBox[{"Conjugate", "[", 
      SubscriptBox["C", "m"], "]"}], 
     SubscriptBox["C", "n"], 
     RowBox[{
      SubscriptBox["f", 
       RowBox[{"m", ",", "0"}]], "[", "r", "]"}], 
     RowBox[{
      SubscriptBox["f", 
       RowBox[{"n", ",", "0"}]], "[", "r", "]"}], 
     SubscriptBox["\[CapitalOmega]", 
      RowBox[{"m", ",", "0"}]], 
     SubscriptBox["\[CapitalOmega]", 
      RowBox[{"n", ",", "0"}]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"m", "-", "n"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{"t", "+", "\[CurlyPhi]"}], ")"}]}], "]"}], "+", 
       RowBox[{"0", " ", "\[ImaginaryI]", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"m", "-", "n"}], ")"}], " ", 
          RowBox[{"(", 
