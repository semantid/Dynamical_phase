Cell[CellGroupData[{

Cell["Closed form expression of type-1 area : sum over m  and n", \
"Subsubsection",
 CellChangeTimes->{{3.988433963154294*^9, 3.9884339713794947`*^9}, {
  3.988434222459343*^9, 3.988434242475472*^9}, {3.988609735327804*^9, 
  3.98860974499848*^9}},ExpressionUUID->"26cfc4f2-9b34-4f24-a5b7-\
694d31f8bab8"],

Cell[TextData[{
 "We use eq. E.9 , where we sum over all m,n to obtain the final area due to \
type-1 ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Delta]g", "r\[CurlyPhi]"], TraditionalForm]],
  ExpressionUUID->"1b574b70-bc66-457b-9c27-c476e0964650"],
 ". We use the value of ( ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "s"], TraditionalForm]],ExpressionUUID->
  "40caa70a-574d-4a93-ac52-a84c42b69fc8"],
 "+ m n ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "p"], TraditionalForm]],ExpressionUUID->
  "7a7f3872-98cb-4b67-975e-e3149eef620d"],
 ") stated in appendix B. The sum for m-n=1 can be easily done. For other \
values of (m-n), we first fix the n, sum over m. Further we find pattern in \
the expressions of several n and then finally sum over n. Below we show these \
patterns for m=0,1,2 and also show the final sum. We use the following \
expression in the sum."
}], "ItemParagraph",
 CellChangeTimes->{{3.988434356947967*^9, 3.988434436348352*^9}, {
  3.988434714821351*^9, 3.988434868244567*^9}, {3.988434981269327*^9, 
  3.988435115108996*^9}, {3.988447414548221*^9, 3.988447432480605*^9}, {
  3.9884475297316437`*^9, 3.988447533483629*^9}, {3.9884476484101458`*^9, 
  3.988447651994595*^9}, {3.988448133368534*^9, 
  3.9884481510961246`*^9}},ExpressionUUID->"705f125a-8bf3-4931-9f0d-\
d959114d6307"],

Cell[BoxData[
 RowBox[{"Amn", " ", "=", " ", 
  RowBox[{
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      SubscriptBox["c", "s"], "+", " ", 
      RowBox[{"m", " ", "n", " ", 
       SubscriptBox["c", "p"]}]}], ")"}], 
    SubscriptBox["\[Kappa]", "m"], 
    SubscriptBox["\[Kappa]", "n"], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"m", "-", "n"}], ")"}], "2"]}], "=", 
   RowBox[{"4", " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], 
     RowBox[{"m", "-", "n"}]], 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"h", 
       RowBox[{"(", 
        RowBox[{"m", "-", "n"}], ")"}]}], "+", "1", "+", "n"}], ")"}], " ", 
    FractionBox[
     RowBox[{"Gamma", "[", 
      RowBox[{
       RowBox[{"2", "h"}], "+", "n"}], "]"}], 
     RowBox[{"Gamma", "[", 
      RowBox[{"2", "h"}], "]"}]], 
    RowBox[{"m", "!"}]}]}]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.988434356947967*^9, 3.988434436348352*^9}, {
  3.988434714821351*^9, 3.988434868244567*^9}, {3.988434981269327*^9, 
  3.988435115108996*^9}, {3.988447414548221*^9, 3.9884475133959303`*^9}, {
