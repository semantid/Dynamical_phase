   SubscriptBox["\[Delta]g", "r\[CurlyPhi]"], "[", "r_", "]"}], ":=", " ", 
  RowBox[{
   RowBox[{
    FractionBox[
     RowBox[{
      TemplateBox[{"s"},
       "C"], "-", 
      FractionBox[
       RowBox[{"8", " ", "\[Pi]", " ", 
        SuperscriptBox["r", 
         RowBox[{"1", "+", "m", "+", "n"}]], " ", 
